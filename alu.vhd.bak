library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity alu is
    port (
        a_in      : in  std_logic_vector(7 downto 0);
        b_in      : in  std_logic_vector(7 downto 0);
        c_in      : in  std_logic;
        op_sel    : in  std_logic_vector(3 downto 0);
        r_out     : out std_logic_vector(7 downto 0);
        flags_out : out std_logic_vector(4 downto 0) -- [N, V, Z, H, C]
    );
end alu;

architecture behavior of alu is
    -- Sinais intermedi·rios para c·lculos
    signal res_extended : unsigned(8 downto 0);
    signal h_arith      : unsigned(4 downto 0);
    signal res_final    : std_logic_vector(7 downto 0);
    signal carry_in_ext : unsigned(8 downto 0);
begin

    -- Extens„o do carry de entrada
    carry_in_ext <= "00000000" & c_in;

    -- Processo Principal da ULA
    process(a_in, b_in, c_in, op_sel, res_extended, h_arith, res_final, carry_in_ext)
        variable v_res_final : std_logic_vector(7 downto 0);
        variable v_flags     : std_logic_vector(4 downto 0);
    begin
        -- Valores padr„o (Reset de vari·veis)
        v_res_final := (others => '0');
        v_flags     := (others => '0');
        res_extended <= (others => '0');
        h_arith      <= (others => '0');

        case op_sel is
            -- ============================================================
            -- OPERA«’ES ARITM…TICAS
            -- ============================================================
            when "0000" => -- ADD
                res_extended <= unsigned('0' & a_in) + unsigned('0' & b_in);
                h_arith      <= unsigned('0' & a_in(3 downto 0)) + unsigned('0' & b_in(3 downto 0));
                v_res_final  := std_logic_vector(res_extended(7 downto 0));
                v_flags(0)   := res_extended(8); -- Carry
                v_flags(1)   := h_arith(4);      -- Half-Carry
                -- Overflow (V)
                v_flags(3)   := (a_in(7) and b_in(7) and (not v_res_final(7))) or 
                                ((not a_in(7)) and (not b_in(7)) and v_res_final(7));

            when "0001" => -- ADDC (Add with Carry)
                res_extended <= unsigned('0' & a_in) + unsigned('0' & b_in) + carry_in_ext;
                h_arith      <= unsigned('0' & a_in(3 downto 0)) + unsigned('0' & b_in(3 downto 0)) + carry_in_ext(4 downto 0);
                v_res_final  := std_logic_vector(res_extended(7 downto 0));
                v_flags(0)   := res_extended(8);
                v_flags(1)   := h_arith(4);
                v_flags(3)   := (a_in(7) and b_in(7) and (not v_res_final(7))) or 
                                ((not a_in(7)) and (not b_in(7)) and v_res_final(7));

            when "0010" => -- SUB
                res_extended <= unsigned('0' & a_in) - unsigned('0' & b_in);
                h_arith      <= unsigned('0' & a_in(3 downto 0)) - unsigned('0' & b_in(3 downto 0));
                v_res_final  := std_logic_vector(res_extended(7 downto 0));
                v_flags(0)   := res_extended(8); -- Borrow (C)
                v_flags(1)   := h_arith(4);      -- Half-Borrow (H)
                -- Overflow (V)
                v_flags(3)   := (a_in(7) and (not b_in(7)) and (not v_res_final(7))) or 
                                ((not a_in(7)) and b_in(7) and v_res_final(7));

            when "0011" => -- SUBC (Subtract with Carry/Borrow)
                res_extended <= unsigned('0' & a_in) - unsigned('0' & b_in) - carry_in_ext;
                h_arith      <= unsigned('0' & a_in(3 downto 0)) - unsigned('0' & b_in(3 downto 0)) - carry_in_ext(4 downto 0);
                v_res_final  := std_logic_vector(res_extended(7 downto 0));
                v_flags(0)   := res_extended(8);
                v_flags(1)   := h_arith(4);
                v_flags(3)   := (a_in(7) and (not b_in(7)) and (not v_res_final(7))) or 
                                ((not a_in(7)) and b_in(7) and v_res_final(7));

            -- ============================================================
            -- OPERA«’ES L”GICAS (Flags de Carry/Overflow/Half zeradas)
            -- ============================================================
            when "0100" => v_res_final := a_in and b_in; -- AND
            when "0101" => v_res_final := a_in or b_in;  -- OR
            when "0110" => v_res_final := a_in xor b_in; -- XOR
            when "0111" => v_res_final := b_in;          -- PASS B
            when "1111" => v_res_final := not a_in;      -- NOT A

            -- ============================================================
            -- DESLOCAMENTOS E ROTA«’ES
            -- ============================================================
            when "1000" => -- RLC (Rotate Left through Carry)
                v_res_final := a_in(6 downto 0) & c_in;
                v_flags(0)  := a_in(7);
            when "1001" => -- RRC (Rotate Right through Carry)
                v_res_final := c_in & a_in(7 downto 1);
                v_flags(0)  := a_in(0);
            when "1010" => -- RL (Rotate Left)
                v_res_final := a_in(6 downto 0) & a_in(7);
                v_flags(0)  := a_in(7);
            when "1011" => -- RR (Rotate Right)
                v_res_final := a_in(0) & a_in(7 downto 1);
                v_flags(0)  := a_in(0);
            when "1100" => -- SLL (Shift Left Logical)
                v_res_final := a_in(6 downto 0) & '0';
                v_flags(0)  := a_in(7);
            when "1101" => -- SRL (Shift Right Logical)
                v_res_final := '0' & a_in(7 downto 1);
                v_flags(0)  := a_in(0);
            when "1110" => -- SRA (Shift Right Arithmetic)
                v_res_final := a_in(7) & a_in(7 downto 1);
                v_flags(0)  := a_in(0);

            when others => v_res_final := (others => '0');
        end case;

        -- AtualizaÁ„o das Flags Universais (Z e N)
        v_flags(4) := v_res_final(7); -- Negative (N)
        if v_res_final = "00000000" then
            v_flags(2) := '1';        -- Zero (Z)
        end if;

        -- AtribuiÁ„o final aos ports
        res_final <= v_res_final;
        r_out     <= v_res_final;
        flags_out <= v_flags;

    end process;
end behavior;